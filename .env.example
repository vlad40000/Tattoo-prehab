# Clerk account authentication. Provision both values for sign-in, sign-up,
# account management, and protected user records. Without them the app keeps
# its existing private on-device mode.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Provision Neon through the Vercel Marketplace and use its pooled connection string.
DATABASE_URL=

# Prefer the direct/unpooled Neon connection for migrations and schema tooling.
# The migration scripts fall back to DATABASE_URL when this is unavailable.
DATABASE_URL_UNPOOLED=

# Minimum 32-byte random value. Signs legacy anonymous-device subjects and
# derives opaque browser account-scope keys used to prevent shared-iPad mixing.
SESSION_SECRET=

# Canonical deployment URL, for example https://tattoo-prehab.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
