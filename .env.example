# Provision Neon through the Vercel Marketplace and use its pooled connection string.
DATABASE_URL=

# Prefer the direct/unpooled Neon connection for migrations and schema tooling.
# The migration scripts fall back to DATABASE_URL when this is unavailable.
DATABASE_URL_UNPOOLED=

# Minimum 32-byte random value used to sign private anonymous-device sessions.
SESSION_SECRET=

# Canonical deployment URL, for example https://machine-hand.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
